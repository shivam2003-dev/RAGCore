# Copy to .env for local development. Never commit .env.

# --- app ---
APP_ENV=local                      # local | staging | production
APP_DEBUG=false
APP_SECRET_KEY=change-me-64-random-chars

# --- database (docker-compose exposes 5433 to avoid clashing with other local pg) ---
DATABASE_URL=postgresql+asyncpg://kimbal:kimbal_dev_password@localhost:5433/kimbal
DATABASE_URL_TEST=postgresql+asyncpg://kimbal:kimbal_dev_password@localhost:5433/kimbal_test

# --- redis ---
REDIS_URL=redis://localhost:6379/0

# --- auth ---
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1209600
AUTH_DISABLED=false               # local/dev only: bypass login and use AUTH_SUPER_ADMIN_EMAIL
AUTH_ALLOWED_EMAIL_DOMAIN=cvum.io
AUTH_SUPER_ADMIN_EMAIL=s.kumar@cvum.io

# --- embeddings ---
EMBEDDING_PROVIDER=openai          # openai | jina | voyage | tei | fake
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BASE_URL=
OPENAI_API_KEY=
JINA_API_KEY=
VOYAGE_API_KEY=

# --- llm ---
LLM_PROVIDER=anthropic             # anthropic | openai | openrouter | fake
LLM_MODEL=claude-sonnet-5
LLM_BASE_URL=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# --- optional LLM Council answer mode ---
# Uses OpenAI-compatible chat completions, typically OpenRouter.
# Runtime shape: two response models draft independently; one different
# evaluator model reviews both drafts and writes the final grounded answer.
LLM_COUNCIL_ENABLED=false
LLM_COUNCIL_MODELS=
LLM_COUNCIL_AVAILABLE_MODELS=anthropic/claude-haiku-4.5,openai/gpt-4.1-mini,google/gemini-2.5-flash
LLM_COUNCIL_CHAIR_MODEL=
LLM_COUNCIL_API_KEY=
LLM_COUNCIL_BASE_URL=https://openrouter.ai/api/v1
LLM_COUNCIL_MAX_MODELS=3
LLM_COUNCIL_TIMEOUT_SECONDS=120

# --- retrieval ---
RETRIEVAL_TOP_K=8
RETRIEVAL_CANDIDATE_K=24
RETRIEVAL_DENSE_WEIGHT=0.7
RETRIEVAL_SPARSE_WEIGHT=0.3
RETRIEVAL_FUSION_MODE=weighted     # weighted | rrf
RETRIEVAL_RRF_SMOOTHING_K=60
RETRIEVAL_EXACT_IDENTIFIER_ENABLED=false
RETRIEVAL_EXACT_IDENTIFIER_WEIGHT=0.25
RETRIEVAL_RARE_TOKEN_ENABLED=false
RETRIEVAL_RARE_TOKEN_WEIGHT=0.15
RETRIEVAL_RECENCY_DECAY_ENABLED=false
RETRIEVAL_RECENCY_HALF_LIVES=jira=45,confluence=180,slack=30,github=90,upload=365,web=14,default=180
RETRIEVAL_RECENCY_FLOOR=0.35
RETRIEVAL_MODEL_RERANKER_ENABLED=false
RETRIEVAL_MODEL_RERANKER_TIMEOUT_SECONDS=3
RETRIEVAL_MODEL_RERANKER_CANDIDATE_K=20
RETRIEVAL_NEIGHBOR_EXPANSION_ENABLED=false
RETRIEVAL_NEIGHBOR_WINDOW=1
RETRIEVAL_NEIGHBOR_TOKEN_BUDGET=1200
RETRIEVAL_NEIGHBOR_MAX_CHUNKS=8
KNOWLEDGE_PLANNER_ENABLED=false
KNOWLEDGE_PLANNER_MODEL_ENABLED=false
KNOWLEDGE_PLANNER_MAX_TOOLS=5
KNOWLEDGE_PLANNER_PER_TOOL_TIMEOUT_SECONDS=4
KNOWLEDGE_PLANNER_OVERALL_TIMEOUT_SECONDS=8

# --- source-aware chunking ---
CHUNK_SIZE_TOKENS=400
CHUNK_OVERLAP_TOKENS=60
JIRA_CHUNK_SIZE_TOKENS=320
JIRA_CHUNK_OVERLAP_TOKENS=40
CONFLUENCE_CHUNK_SIZE_TOKENS=400
CONFLUENCE_CHUNK_OVERLAP_TOKENS=60

# --- limits ---
UPLOAD_MAX_BYTES=52428800          # 50 MB
RATE_LIMIT_PER_MINUTE=300

# --- Confluence Cloud read-only sync ---
# Use a site root or a space URL; the backend normalizes it to /wiki.
CONFLUENCE_BASE_URL=https://your-domain.atlassian.net/wiki
CONFLUENCE_SPACE_KEY=DevOps1
CONFLUENCE_API_TOKEN=
# Standard Atlassian Cloud API tokens require the account email for Basic auth.
CONFLUENCE_EMAIL=
CONFLUENCE_AUTH_MODE=auto          # auto | basic | bearer
CONFLUENCE_DEFAULT_KB_NAME=Confluence DevOps1
CONFLUENCE_PAGE_LIMIT=100          # per-request page size
CONFLUENCE_SYNC_MAX_PAGES=0        # 0 syncs all visible pages

# --- Jira Software Cloud read-only sync ---
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_PROJECT_KEY=DEVO
JIRA_BOARD_ID=154
# Optional. If blank, the backend falls back to CONFLUENCE_EMAIL/API_TOKEN for the same Atlassian site.
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_AUTH_MODE=auto               # auto | basic | bearer
JIRA_DEFAULT_KB_NAME=Jira DEVO
JIRA_ISSUE_LIMIT=100              # per-request page size
JIRA_SYNC_MAX_ISSUES=500          # routine refresh bound; 0 opts into every visible issue
JIRA_INCLUDE_ISSUE_TYPES=
JIRA_EXCLUDE_ISSUE_TYPES=
JIRA_DROP_EMPTY_DESCRIPTIONS=false
JIRA_INCLUDE_COMMENTS=true
JIRA_MAX_COMMENTS_PER_ISSUE=100
JIRA_EXTRACT_ATTACHMENTS=true
JIRA_MAX_ATTACHMENTS_PER_ISSUE=10
JIRA_ATTACHMENT_MAX_BYTES=5242880
JIRA_HYDRATION_CONCURRENCY=8

# --- Slack Socket Mode read-only public-channel ingestion ---
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=
SLACK_WORKSPACE_ID=
SLACK_DEFAULT_KB_NAME_PREFIX=Slack
SLACK_REQUEST_TIMEOUT_SECONDS=20
SLACK_API_MAX_RETRIES=3
SLACK_HISTORY_LIMIT=15
SLACK_BURST_MIN_MESSAGES=2
SLACK_BURST_RARE_TOKEN_THRESHOLD=2
SLACK_BURST_REACTION_THRESHOLD=2
SLACK_SUMMARY_MAX_CHARS=1800

# --- GitHub read-only code indexing ---
# Prefer a GitHub App installation token in production.
GITHUB_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_API_VERSION=2026-03-10
GITHUB_DEFAULT_BRANCH=main
GITHUB_REQUEST_TIMEOUT_SECONDS=20
GITHUB_API_MAX_RETRIES=3
GITHUB_MAX_FILES_PER_SYNC=2000
GITHUB_MAX_BLOB_BYTES=1000000
GITHUB_RECENT_PR_LIMIT=20
# A crashed worker's lease becomes recoverable after this interval.
GITHUB_SYNC_LEASE_SECONDS=1800
# Leave blank to use the conservative built-in list. Never allow secret-like paths.
GITHUB_DEFAULT_PATH_DENYLIST=

# --- optional web search for Ask ---
# Providers: tavily, brave, searxng, duckduckgo. Tavily is recommended for production Ask.
WEB_SEARCH_PROVIDER=disabled
WEB_SEARCH_API_KEY=
WEB_SEARCH_BASE_URL=
WEB_SEARCH_DEFAULT_KB_NAME=Web Search
WEB_SEARCH_TOP_K=5

# --- Discover live department feeds ---
# This powers /discover with department updates, articles, alerts, research, and
# a local Jira/Confluence board pulse. Keep provider keys in backend/.env or a
# secret manager only; never commit real keys.
DISCOVER_ENABLED=true
# Local/no-key option: google_news_rss. Stronger production options: brave,
# tavily, searxng, or duckduckgo. Use fake only for tests/offline demos.
DISCOVER_PROVIDER=google_news_rss
# Update this only for brave or tavily. Leave blank for google_news_rss,
# duckduckgo, searxng, and fake.
DISCOVER_API_KEY=
# Update this for self-hosted SearXNG or provider endpoint overrides.
# Examples:
# - SearXNG: https://search.your-company.internal
# - Google News RSS override: https://news.google.com/rss/search
DISCOVER_BASE_URL=
# Update locale/region for the organization's default news lens.
DISCOVER_LOCALE=en-IN
DISCOVER_REGION=IN
# Cache external article fetches per process to reduce provider calls.
DISCOVER_CACHE_TTL_SECONDS=900
DISCOVER_ITEMS_PER_DEPARTMENT=8
# Optional query overrides. Separate entries with semicolons or new lines.
# Example:
# DISCOVER_DEPARTMENT_QUERIES=security=cybersecurity zero day CVE exploit patch;devops=Kubernetes ArgoCD GitOps production
DISCOVER_DEPARTMENT_QUERIES=
